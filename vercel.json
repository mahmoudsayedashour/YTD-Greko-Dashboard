{
  "version": 2,
  "functions": {
    "api/data.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/data",
      "destination": "/api/data.js"
    },
    {
      "source": "/api/data/(.*)",
      "destination": "/api/data.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
